          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login correcto', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.token) pm.environment.set('token', data.token);",
                  "if (data.rol) pm.environment.set('rol', data.rol);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
